# ── Supabase ──────────────────────────────────────────────────────────────────

# Project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key — bypasses Row Level Security. NEVER expose to the client.
SUPABASE_SECRET_KEY=
